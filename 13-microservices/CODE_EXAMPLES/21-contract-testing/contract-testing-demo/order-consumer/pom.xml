<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.example</groupId>
        <artifactId>contract-testing-demo</artifactId>
        <version>1.0.0</version>
    </parent>

    <artifactId>order-consumer</artifactId>

    <!--
      The CONSUMER side. Stub Runner (test scope) resolves inventory-provider's stubs jar from
      ~/.m2, boots a WireMock server from the contract-generated mappings, and the real
      order-service client calls it. Because the stub is generated from the SAME contract the
      provider is verified against, it cannot silently drift from real provider behaviour — the
      gap a hand-written stub (topic 20) leaves open.
    -->
    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.springframework.cloud</groupId>
            <artifactId>spring-cloud-starter-contract-stub-runner</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>
</project>
